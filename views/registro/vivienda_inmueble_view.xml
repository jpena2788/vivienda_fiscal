    <record id="action_vf_inmueble" model="ir.actions.act_window">
        <field name="name">Inmuebles</field>
        <field name="res_model">vivienda.inmueble</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_vf_inmueble"
                  name="Inmueble"
                  parent="vivienda_fiscal.menu_vf_root_reg"
                  sequence="2"
                  action="action_vf_inmueble" />
