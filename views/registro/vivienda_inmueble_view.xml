    <record id="view_vivienda_inmueble_search" model="ir.ui.view">
        <field name="name">vivienda.inmueble.search</field>
        <field name="model">vivienda.inmueble</field>
        <field name="arch" type="xml">
            <search>
                <field name="reparto_id"/>
                <field name="sector_id"/>
                <field name="name" />
                <field name="address"/>
                <filter name="f_disponible" string="Disponibles" domain="[('estado','=','disponible')]"/>
                <filter name="f_ocupado" string="Ocupados" domain="[('estado','=','ocupado')]"/>
                <filter name="f_mantenimiento" string="Mantenimiento" domain="[('estado','=','mantenimiento')]"/>
                <group>
                    <filter name="sector" string="Sector" context="{'group_by': 'sector_id'}"/>
                    <filter name="reparto" string="Agrupar Reparto" context="{'group_by': 'reparto_id'}" />
                    <filter string="Inactivo" name="inactive" domain="[('active','=',False)]" />
                </group>
            </search>
        </field>
    </record>
    <record id="action_vivienda_inmueble_server" model="ir.actions.server">
        <field name="name">INMUEBLES</field>
        <field name="model_id" ref="model_vivienda_inmueble" />
        <field name="binding_model_id" ref="model_vivienda_inmueble" />
        <field name="state">code</field>
        <field name="code">action = env['vivienda.inmueble'].ver_inmueble()</field>
    </record>
