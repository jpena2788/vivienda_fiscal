<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vf_dashboard_tree" model="ir.ui.view">
        <field name="name">vf.dashboard.list</field>
        <field name="model">vf.dashboard</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="occupied_houses"/>
                <field name="available_houses"/>
                <field name="occupied_beds"/>
                <field name="available_beds"/>
            </list>
        </field>
    </record>

    <record id="act_vf_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard Vivienda</field>
        <field name="res_model">vf.dashboard</field>
        <field name="view_mode">list</field>
        <field name="target">current</field>
    </record>
</odoo>
