<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_vf_vivienda_entrega" model="ir.actions.report">
        <field name="name">Certificado Entrega Vivienda</field>
        <field name="model">vf.vivienda.asignacion</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">vivienda_fiscal.report_vf_vivienda_entrega_template</field>
        <field name="print_report_name">(object.name or 'entrega') + '.pdf'</field>
    </record>

    <record id="action_report_vf_vivienda_liberacion" model="ir.actions.report">
        <field name="name">Certificado Liberación Vivienda</field>
        <field name="model">vf.vivienda.asignacion</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">vivienda_fiscal.report_vf_vivienda_liberacion_template</field>
        <field name="print_report_name">(object.name or 'liberacion') + '.pdf'</field>
    </record>

    <record id="report_vf_ocupacion" model="ir.actions.report">
        <field name="name">Reporte Ocupación</field>
        <field name="model">vf.alojamiento.naval</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">vivienda_fiscal.report_vf_ocupacion</field>
        <field name="print_report_name">'ocupacion-'+(object.name or 'general') + '.pdf'</field>
    </record>
</odoo>
