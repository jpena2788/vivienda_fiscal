<odoo>
  <data>
    <record model="ir.ui.view" id="view_vivienda_ambiente_tree">
      <field name="name">vivienda.ambiente</field>
      <field name="model">vivienda.ambiente</field>
      <field name="arch" type="xml">
        <list>
          <field name="name" />
          <field name="inmueble_id"/>
          <field name="piso_id" />
          <field name="tipo_ambiente_id" />
          <field name="state" />
          <button name="action_libre"
            string="Libre"
            type="object"
            icon="fa-thumbs-up"
            class="oe_highlight"
            invisible="state != 'libre'"/>
        </list>
      </field>
    </record>
    <record id="view_vivienda_ambiente_search" model="ir.ui.view">
      <field name="name">vivienda.ambiente</field>
      <field name="model">vivienda.ambiente</field>
      <field name="arch" type="xml">
        <search string="">
          <field name="inmueble_id"/>
          <field name="name" />
          <!-- <field name="caracteristica_ids" /> -->
          <field name="piso_id" />
          <field name="state" />
          <group>
            <filter name="reparto" string="Agrupar Reparto" context="{'group_by': 'reparto_id'}" />
            <filter name="inmueble" string="Agrupar Inmueble" context="{'group_by': 'inmueble_id'}" />
            <filter name="estado" string="Agrupar por estado" context="{'group_by': 'state'}" />
          </group>
        </search>
      </field>
    </record>
    <record id="view_vivienda_ambiente_form" model="ir.ui.view">
      <field name="name">vivienda.ambiente.form</field>
      <field name="model">vivienda.ambiente</field>
      <field name="arch" type="xml">
        <form string="Ambiente">
          <!-- HEADER -->
          <header>
            <field name="state" widget="statusbar"/>
            <button name="action_libre" string="Libre" type="object" class="btn-primary" invisible="state not in ['mantenimiento','no_op','ocupado','operativo','opcl']"/>
            <button name="action_operativo" string="Operativo" type="object" class="btn-primary" invisible="state not in ['libre','mantenimiento','no_op','ocupado','opcl']"/>
            <button name="action_mantenimiento" string="Mantenimiento" type="object" class="btn-warning" invisible="state not in ['libre','no_op','ocupado','operativo','opcl']"/>
            <button name="action_operativo_limitacion" string="Operativo con Limitaciones" type="object" class="btn-secondary" invisible="state not in ['libre','no_op','mantenimiento','ocupado','operativo']"/>
            <button name="action_no_operativo" string="No operativo" type="object" class="btn-danger" invisible="state not in ['libre','mantenimiento','ocupado','operativo','opcl']"/>
            <button name="action_ocupado" string="Ocupado" type="object" class="btn-success" invisible="state not in ['libre','mantenimiento','no_op','operativo','opcl']"/>
           </header>
          <!-- CONTENIDO -->
          <sheet>
            <!-- TITULO -->
            <div class="oe_title">
              <h1>
                <field name="name" placeholder="Nombre del ambiente"/>
              </h1>
            </div>
            <!-- GRID CORRECTO -->
            <group col="2">
              <!-- IZQUIERDA -->
              <group>
                <field name="inmueble_id"/>
                <field name="piso_id"/>
                <field name="tipo_ambiente_id"/>
                <field name="active" widget="boolean_toggle"/>
              </group>
              <!-- DERECHA (IMAGEN GRANDE) -->
              <group>
                <field name="foto_ambiente" widget="image" options="{'size': [250, 250]}"/>
              </group>
            </group>
          </sheet>
          <!-- CHATTER SIEMPRE FUERA DEL SHEET -->
          <!-- <div class="oe_chatter">
            <field name="message_ids" widget="mail_thread"/>
          </div> -->
        </form>
      </field>
    </record>
