<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vf_vivienda_asignacion_list" model="ir.ui.view">
        <field name="name">vf.vivienda.asignacion.list</field>
        <field name="model">vf.vivienda.asignacion</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="inmueble_id"/>
                <field name="empleado_id"/>
                <field name="fecha_inicio"/>
                <field name="fecha_fin"/>
                <field name="active"/>
                <field name="estado"/>
            </list>
        </field>
    </record>

    <record id="view_vf_vivienda_asignacion_form" model="ir.ui.view">
        <field name="name">vf.vivienda.asignacion.form</field>
        <field name="model">vf.vivienda.asignacion</field>
        <field name="arch" type="xml">
            <form string="Asignación Vivienda">
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                         <field name="tipo_inmueble_id"/>
                         <field name="inmueble_id"/>
                        <field name="empleado_id"/>
                        <field name="fecha_inicio"/>
                        <field name="fecha_fin"/>
                        <field name="active"/>
                        <field name="estado"/>
                    </group>
                    <footer>
                        <button string="Aprobar" type="object" name="action_activate" class="btn-primary"/>
                        <button string="Finalizar" type="object" name="action_finish" class="btn-secondary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vf_vivienda_asignacion" model="ir.actions.act_window">
        <field name="name">Asignaciones Vivienda</field>
        <field name="res_model">vf.vivienda.asignacion</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
