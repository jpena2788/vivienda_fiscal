<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="view_vivienda_tipo_ambiente_tree">
            <field name="name">vivienda.tipo_ambiente</field>
            <field name="model">vivienda.tipo_ambiente</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name" />
                    <field name="descripcion" />
                </list>
            </field>
        </record>

        <record id="view_vivienda_tipo_ambiente_form" model="ir.ui.view">
            <field name="name">vivienda.tipo_ambiente</field>
            <field name="model">vivienda.tipo_ambiente</field>
            <field name="arch" type="xml">
                <form string="NUEVO" duplicate="0">
                    <sheet>
                        <group>
                            <group >
                                <field name="name" />                               
                                <field name="active" widget="boolean_toggle" />
                            </group>
                            <group >
                                <field name="descripcion" />
                            </group>
                        </group>
                        <div class="oe_chatter">
                            <field name="message_ids" widget="mail_thread" />
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_vivienda_tipo_ambiente_presentacion_form" model="ir.ui.view">
            <field name="name">vivienda.tipo_ambiente</field>
            <field name="model">vivienda.tipo_ambiente</field>
            <field name="arch" type="xml">
                <form string="NUEVO">
                    <sheet>
                        <group>
                            <group>
                                <field name="name" readonly="1" />
                            </group>
                            <group>
                                <field name="descripcion" readonly="1" />
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_vivienda_tipo_ambiente_search" model="ir.ui.view">
            <field name="name">vivienda.tipo_ambiente</field>
            <field name="model">vivienda.tipo_ambiente</field>
            <field name="arch" type="xml">
                <search string="">
                    <field name="name" />
                    <field name="descripcion" />
                    <group>
                        <filter string="Inactivo" name="inactive" domain="[('active','=',False)]" />
                    </group>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="action_vivienda_tipo_ambiente">
            <field name="name">TIPO AMBIENTE</field>
            <field name="res_model">vivienda.tipo_ambiente</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem name="Tipo de Ambiente" id="menu_action_vivienda_tipo_ambiente" parent="vivienda_fiscal.menu_vf_root_reg" action="action_vivienda_tipo_ambiente" sequence="1" />

    </data>
</odoo>