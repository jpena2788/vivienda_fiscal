<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vivienda_inmueble_list" model="ir.ui.view">
        <field name="name">vivienda.inmueble.list</field>
        <field name="model">vivienda.inmueble</field>
        <field name="arch" type="xml">
            <list string="Inmuebles">
                <field name="name"/>
                <field name="address"/>
                <field name="tipo_inmueble_id"/>
                <field name="sector_id"/>
                <field name="reparto_id"/>
                <field name="estado"/>
                <field name="condicion" />
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_vivienda_inmueble_form" model="ir.ui.view">
        <field name="name">vivienda.inmueble.form</field>
        <field name="model">vivienda.inmueble</field>
        <field name="arch" type="xml">
            <form string="Inmueble">
                <sheet>
                    <!-- TITULO -->
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <!-- DATOS GENERALES -->
                    <group string="Información General">
                        <group>
                            <field name="description"/>
                            <field name="address"/>
                            <field name="tipo_inmueble_id"/>
                            <field name="sector_id"/>
                            <field name="reparto_id"/>
                            <field name="tipo_huesped_ids" required="1" widget="many2many_tags" options="{'no_create': True, 'no_open': True, 'no_create_edit': True}" />
                        </group>
                        <group>
                            <field name="bloque"/>
                            <field name="numero"/>
                            <field name="estado"/>
                            <field name="active"/>
                            <field name="condicion"/>
                        </group>
                    </group>
                    <notebook>
                        <!-- POLÍTICAS -->
                        <page string="Políticas">
                            <group string="Políticas">
                                <field name="politicas_ids" widget="many2many_tags"/>
                            </group>
                        </page>
                        <!-- AMBIENTES -->
                        <page string="Ambientes">
                            <field name="ambiente_ids" widget="one2many_list" nolabel="1">
                                <list string="Ambientes del Inmueble" editable="bottom">
                                    <field name="name" />
                                    <field name="state" />
                                    <field name="active" widget="boolean_toggle" />
                                </list>
                            </field>
                        </page>
                        <!-- CONFIGURACIÓN -->
                        <page string="Configuración" invisible="condicion == 'permanente'">
                            <group string="Configuración de Reserva">
                                <group>
                                    <field name="hora_entrada"/>
                                    <field name="hora_salida"/>
                                </group>
                                <group>
                                    <field name="dia_anticipacion"/>
                                    <field name="dia_anticipacion_maximo"/>
                                </group>
                            </group>
                            <!-- CONTROL -->
                            <group string="Control">
                                <group>
                                    <field name="numero_ambiente_reservada"/>
                                    <field name="ambiente_usuario"/>
                                    <field name="dias_pago"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
