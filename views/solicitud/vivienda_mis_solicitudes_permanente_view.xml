<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="view_vivienda_mis_solicitud_permanente_tree">
            <field name="name">vivienda.inmueble_asignado</field>
            <field name="model">vivienda.inmueble_asignado</field>
            <field name="arch" type="xml">
                <list>
                    <field name="condicion" optional="hide"/>
                    <field name="reparto_solicitud_empleado" />
                    <field name="personal_id" />
                    <field name="reparto_id" />
                    <field name="sector_id" />
                    <field name="inmueble_id" />
                    <field name="state" widget="badge" decoration-bf="state == 'draft'" decoration-primary="state == 'revision'" decoration-success="state == 'asignado'"  decoration-warning="state == 'lista_espera'" decoration-danger="state == 'anular'"/>
                    <button name="action_estado_por_anular" string="Anular" type="object" icon="fa-ban" class="btn-danger" invisible="state not in ['draft','revision']"/>
                    <button name="action_archivar" string="Archivar" type="object" icon="fa-archive" class="btn-secondary" invisible="(condicion == 'permanente' and state not in ['anular','baja']) or (condicion == 'temporal' and state not in ['anular','fin'])"/>
                </list>
            </field>
        </record>
        <record id="view_vivienda_mis_solicitud_permanente_form" model="ir.ui.view">
            <field name="name">vivienda.inmueble_asignado</field>
            <field name="model">vivienda.inmueble_asignado</field>
            <field name="arch" type="xml">
                <form string="NUEVO" duplicate="0">
                    <header>
                        <field name="state" widget="statusbar" statusbar_visible="draft,anular,revision,devuelto,rechazado,lista_espera,asignado,baja" invisible="not es_solicitud_permanente"/>
                        <button name="action_estado_por_anular" string="Anular" type="object" icon="fa-ban" class="btn-secondary" invisible="state != 'draft'"/>
                        <button name="solicitar_inmueble" invisible="state not in ['draft', 'devuelto']" string="Solicitar" type="object" icon="fa-check" class="oe_highlight"/>
                        <button name="action_eliminar" invisible="state != 'draft'" string="Eliminar" type="object" icon="fa-trash" class="btn-danger" confirm="¿Está seguro de que desea eliminar esta solicitud? Esta acción no se puede deshacer."/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <!-- Bloque superior en 2 columnas -->
                        <group col="2">
                            <!-- IZQUIERDA: persona + inmueble -->
                            <group string="Datos de la Solicitud">
                                <field name="personal_id"
                                           style="color:black; font-weight: bold;font-size: x-large"
                                           domain="[('user_id', '=', uid)]"
                                           options="{'no_create': True, 'no_open': True, 'no_create_edit': True}"
                                           readonly="state != 'draft'"/>
                                <field name="personal_permitido_ids" invisible="1"/>
                                <field name="user_id"
                                           options="{'no_create': True, 'no_open': True, 'no_create_edit': True}"
                                           force_save="1" invisible="1"/>
                                <field name="inmueble_id_domain" invisible="1"/>
                                <field name="sector_permanente_dominio" invisible="1"/>
                                <field name="sector_id"
                                           string="Sector"
                                           domain="sector_permanente_dominio"
                                           options="{'no_create': True, 'no_open': True, 'no_create_edit': True}"
                                           readonly="state != 'draft'" required="1" force_save="1"/>
                                <field name="inmueble_id" 
                                           group="vivienda_fiscal.group_vivienda_encargado_solicitud" 
                                           domain="[('condicion', '=', 'permanente')] + ([('sector_id', '=', sector_id)] if sector_id else [])"
                                           options="{'no_create': True, 'no_open': True, 'no_create_edit': True}"
                                           invisible="state in ['draft', 'revision']"/>
                                <field name="reparto_id" readonly="1" force_save="1"/>
                                <field name="condicion" invisible="1"/>
                                <field name="aceptacion_termino" readonly="state != 'draft'"/>
                                <field name="fecha_alta" invisible="state == 'draft'" readonly="1"/>
                                <field name="fecha_baja" invisible="state == 'draft'" readonly="1"/>
                            </group>
                            <!-- DERECHA: ambientes del inmueble -->
                            <group string="Ambientes disponibles del inmueble" invisible="not inmueble_id">
                                <field name="inmueble_ambiente_ids" nolabel="1" readonly="1">
                                    <list create="0" delete="0" edit="0">
                                        <field name="sequence" widget="handle"/>
                                        <field name="ambiente_id"/>
                                        <field name="descripcion"/>
                                        <field name="active"/>
                                    </list>
                                </field>
                            </group>
                        </group>
                        <group>
                            <group colspan="2">
                                <field name="observacion" readonly="state != 'draft'"/>
                            </group>
                            <strong colspan="2">
                                <group string="Motivo del rechazo" invisible="state != 'anular'">
                                    <strong>
                                        <h1>
                                            <field name="motivo_rechazo" colspan="4" nolabel="1"/>
                                        </h1>
                                    </strong>
                                </group>
                            </strong>
                        </group>
                        <notebook>
                            <page string="Requisitos">
                                <group>
                                    <field name="requisito_line_ids" nolabel="1" readonly="state not in ['draft', 'devuelto']">
                                        <list editable="bottom" create="0" delete="0">
                                            <field name="sequence" widget="handle"/>
                                            <field name="requisito_id" readonly="1"/>
                                            <field name="tipo_captura" readonly="1" optional="hide"/>
                                            <field name="obligatorio" readonly="1" optional="hide"/>
                                            <field name="valor_texto" invisible="tipo_captura != 'texto'" readonly="state != 'devuelto'"/>
                                            <field name="archivo" filename="archivo_nombre" invisible="tipo_captura != 'archivo'" readonly="state != 'devuelto'"/>
                                            <field name="archivo_nombre" invisible="1"/>
                                            <field name="aprobado" readonly="1" widget="boolean_toggle" optional="show"/>
                                            <field name="observacion_revision" readonly="1" optional="show"/>
                                        </list>
                                    </field>
                                </group>
                            </page>
                            <!-- POLÍTICAS -->
                            <page string="Políticas">
                                <group string="Políticas">
                                    <field name="politicas_ids" widget="many2many_tags"/>
                                </group>
                            </page>
                            <page string="Dependientes">
                                <group colspan="2" string="Dependientes">
                                    <field name="dependiente_ids" nolabel="1" options="{'no_create': True, 'no_open': True, 'no_create_edit': True}" readonly="state != 'draft'">
                                        <list limit="5">
                                            <field name="parentesco" />
                                            <field name="apellido_paterno"/>
                                            <field name="apellido_materno" />
                                            <field name="primer_nombre" />
                                            <field name="segundo_nombre" />
                                        </list>
                                        <form>
                                            <group>
                                                <group>
                                                    <field name="apellido_paterno" readonly="1" />
                                                    <field name="primer_nombre" readonly="1"/>
                                                    <field name="parentesco" readonly="1"/>
                                                </group>
                                                <group>
                                                    <field name="apellido_materno" readonly="1"/>
                                                    <field name="segundo_nombre" readonly="1"/>
                                                </group>
                                            </group>
                                        </form>
                                    </field>
                                </group>
                            </page>
                            <page string="Información del solicitante">
                                <group >
                                    <group >
                                        <field name="email"/>
                                        <field name="telefono"/>
                                    </group>
                                    <group >
                                        <field name="cedula_identidad"/>
                                        <field name="reparto_empleado_id"/>
                                    </group>
                                    <group colspan="2">
                                        <field name="direccion" />
                                    </group>
                                </group>
                            </page>
                        </notebook>
                        <!-- <div class="oe_chatter">
                            <field name="message_ids" widget="mail_thread" />
                        </div> -->
                    </sheet>
                </form>
            </field>
        </record>
        <record id="view_vivienda_mis_solicitud_permanente_search" model="ir.ui.view">
            <field name="name">vivienda.inmueble_asignado</field>
            <field name="model">vivienda.inmueble_asignado</field>
            <field name="arch" type="xml">
                <search string="">
                    <field name="personal_id" />
                    <field name="cedula_identidad" />
                    <field name="sector_id" string="Sector"/>
                    <field name="inmueble_id" />
                    <field name="fecha_alta" />
                    <field name="fecha_baja" />
                    <field name="state" />
                    <group>
                        <filter name="sector" string="Sector" context="{'group_by': 'sector_id'}" />
                        <filter name="estado" string="Estado" context="{'group_by': 'state'}" />
                    </group>
                </search>
            </field>
        </record>
        <record model="ir.actions.act_window" id="action_vivienda_mis_solicitud_permanente">
            <field name="name">SOLICITUD DE VIVIENDA PERMANENTE</field>
            <field name="res_model">vivienda.inmueble_asignado</field>
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('vivienda_fiscal.view_vivienda_mis_solicitud_permanente_tree')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('vivienda_fiscal.view_vivienda_mis_solicitud_permanente_form')}),]" />
            <field name="search_view_id" ref="vivienda_fiscal.view_vivienda_mis_solicitud_permanente_search"/>
            <field name="domain">[('user_id','=', context.get('uid')),('es_archivar','=', False),('es_solicitud_permanente','=',True)]</field>
            <field name="context" eval="{'default_es_solicitud_permanente': True}"></field>
        </record>
        <menuitem name="Solicitud de Vivienda Permanente" id="menu_action_vivienda_mis_solicitud_permanente" parent="vivienda_fiscal.menu_vf_root_sol" action="action_vivienda_mis_solicitud_permanente" sequence="3" />
    </data>
</odoo>