<?xml version="1.0" encoding="utf-8"?>
<odoo>

    
    <!-- WIZARD -->
    <record id="view_historial_vivienda_wizard" model="ir.ui.view">
        <field name="name">vf.historial.wizard.form</field>
        <field name="model">vf.historial.wizard</field>
        <field name="arch" type="xml">

            <form string="Consulta Historial Vivienda">

                <group>

                    <field name="empleado_id" />

                    <field name="cedula" />

                </group>

                <footer>

                    <button name="action_generar_reporte" type="object" string="Generar Certificación" class="btn-primary" />

                    <button string="Cancelar" special="cancel" class="btn-secondary" />

                </footer>

            </form>

        </field>
    </record>

    <!-- ACCION PARA ABRIR EL WIZARD -->
    <record id="action_historial_vivienda_wizard" model="ir.actions.act_window">
        <field name="name">Certificación Histórica Vivienda</field>
        <field name="res_model">vf.historial.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

     
</odoo>