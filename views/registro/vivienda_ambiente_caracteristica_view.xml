<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="view_vivienda_ambiente_caracteristica_tree">
            <field name="name">vivienda.ambiente_caracteristica</field>
            <field name="model">vivienda.ambiente_caracteristica</field>
            <field name="arch" type="xml">
                <list>
                    <field name="ambiente_id" />
                    <field name="inmueble_id" />
                    <field name="caracteristicas_ids" widget="many2many_tags" />
                </list>
            </field>
        </record>
        <record id="view_vivienda_ambiente_caracteristica_search" model="ir.ui.view">
            <field name="name">vivienda.ambiente_caracteristica</field>
            <field name="model">vivienda.ambiente_caracteristica</field>
            <field name="arch" type="xml">
                <search string="">
                    <field name="reparto_id" />
                    <field name="ambiente_id" />
                    <field name="caracteristicas_ids"/>
                    <group>
                        <filter name="reparto" string="Agrupar Reparto" context="{'group_by': 'reparto_id'}" />
                        <filter name="inmueble" string="Agrupar Inmueble" context="{'group_by': 'inmueble_id'}" />
                        <filter string="Eliminado" name="inactive" domain="[('active','=',False)]" />
                    </group>
                </search>
            </field>
        </record>
        <record id="view_vivienda_ambiente_caracteristica_form" model="ir.ui.view">
            <field name="name">vivienda.ambiente_caracteristica</field>
            <field name="model">vivienda.ambiente_caracteristica</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="marca" create="true" delete="true" edit="true">
                    <header></header>
                    <sheet>
                        <group>
                            <group colspan="2">
                                <field name="inmueble_id" required="1" placeholder="Seleccione el inmueble" options="{'no_create': True, 'no_open': True, 'no_create_edit': True}" />
                            </group>
                            <group>
                                <field name="ambiente_id_domain" invisible="1"/>
                                <field name="ambiente_id" domain="ambiente_id_domain" placeholder="Escriba el nombre del ambiente.." options="{'no_create': True, 'no_open': True, 'no_create_edit': True}"/>
                                <field name="num_personas"/>
                                <field name="active" widget="boolean_toggle" />
                            </group>
                            <group>
                                <field name="descripcion" placeholder="Escriba alguna descripción.." />
                                <field name="precio" placeholder="Escriba el precio de este tipo de ambbiente.." />
                            </group>
                        </group>
                        <group string="Características">
                            <group >
                                <field name="caracteristicas_ids" nolabel="1">
                                    <list editable="top">
                                        <field name="caracteristica_id_domain" invisible="1"/>
                                        <field name="caracteristica_id" domain="caracteristica_id_domain" options="{'no_create': True, 'no_open': True, 'no_create_edit': True}" />
                                        <field name="valor_ids" widget="many2many_tags"/>
                                    </list>
                                </field>
                            </group>
                        </group>
                    </sheet>
                    <!-- <div class="oe_chatter">
                        <field name="message_ids" widget="mail_thread" />
                    </div> -->
                </form>
            </field>
        </record>
        <record id="view_vivienda_ambiente_caracteristica_one2many_form" model="ir.ui.view">
            <field name="name">vivienda.ambiente_caracteristica</field>
            <field name="model">vivienda.ambiente_caracteristica</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="marca" create="true" delete="true" edit="true">
                    <header></header>
                    <sheet>
                        <group>
                            <group>
                                <field name="ambiente_id_domain" invisible="1"/>
                                <field name="ambiente_id" domain="ambiente_id_domain" options="{'no_create': True, 'no_open': True, 'no_create_edit': True}" placeholder="Seleccione el tipo de habitación.." />
                                <field name="num_personas"/>
                                <field name="active" widget="boolean_toggle" />
                            </group>
                            <group>
                                <field name="precio" placeholder="Escriba el precio de este tipo de habitación.." />
                            </group>
                            <group colspan="2" string="Características">
                                <field name="caracteristicas_ids" nolabel="1">
                                    <list editable="top">
                                        <field name="caracteristica_id_domain" invisible="1"/>
                                        <field name="caracteristica_id" domain="caracteristica_id_domain" options="{'no_create': True, 'no_open': True, 'no_create_edit': True}" />
                                        <field name="valor_ids" widget="many2many_tags"/>
                                    </list>
                                </field>
                            </group>
                        </group>
                    </sheet>
                    <!-- <div class="oe_chatter">
                        <field name="message_ids" widget="mail_thread" />
                    </div> -->
                </form>
            </field>
        </record>
        <record model="ir.actions.act_window" id="action_vivienda_ambiente_inmueble">
            <field name="name">Características de Ambientes</field>
            <field name="res_model">vivienda.ambiente_caracteristica</field>
            <field name="view_mode">list,form</field>
            <field name="context" eval="{'search_default_reparto':1,'search_default_inmueble':1}"></field>
        </record>
        <record id="action_vivienda_ambiente_caracteristica_server" model="ir.actions.server">
            <field name="name">Características de Ambientes</field>
            <field name="model_id" ref="model_vivienda_ambiente_caracteristica" />
            <field name="binding_model_id" ref="model_vivienda_ambiente_caracteristica" />
            <field name="state">code</field>
            <field name="code">action = env['vivienda.ambiente_caracteristica'].ver_ambientes()</field>
        </record>
        <menuitem name="Características de Ambientes" id="menu_action_inmueble_ambiente" parent="vivienda_fiscal.menu_vf_root_reg" action="action_vivienda_ambiente_caracteristica_server" sequence="4" />
    </data>
</odoo>