<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="view_vivienda_hora_entrada_salida_tree">
            <field name="name">vivienda.hora_entrada_salida</field>
            <field name="model">vivienda.hora_entrada_salida</field>
            <field name="arch" type="xml">
                <list create="0">
                    <field name="hora_entrada" widget='float_time'/>
                    <field name="hora_salida" widget='float_time'/>
                </list>
            </field>
        </record>

        <record id="view_vivienda_hora_entrada_salida_form" model="ir.ui.view">
            <field name="name">vivienda.hora_entrada_salida</field>
            <field name="model">vivienda.hora_entrada_salida</field>
            <field name="arch" type="xml">
                <form string="NUEVO" duplicate="0" create="0">
                    <sheet>
                        <group>
                            <group >                              
                                <field name="hora_entrada" widget='float_time'/>
                            </group>
                            <group >
                                <field name="hora_salida" widget='float_time' />
                            </group>
                        </group>
                        <div class="oe_chatter">
                            <field name="message_ids" widget="mail_thread" />
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_vivienda_hora_entrada_salida_presentacion_form" model="ir.ui.view">
            <field name="name">vivienda.hora_entrada_salida</field>
            <field name="model">vivienda.hora_entrada_salida</field>
            <field name="arch" type="xml">
                <form string="NUEVO">
                    <sheet>
                        <group>
                            <group >
                                <field name="hora_entrada" widget='float_time' readonly="1" />
                            </group>
                            <group >
                                <field name="hora_salida" widget='float_time' readonly="1" />
                            </group>

                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_vivienda_hora_entrada_salida_search" model="ir.ui.view">
            <field name="name">vivienda.hora_entrada_salida</field>
            <field name="model">vivienda.hora_entrada_salida</field>
            <field name="arch" type="xml">
                <search string="">
                    <field name="hora_entrada" />
                    <field name="hora_salida" />
                    <!-- <group>
                        <filter string="Inactivo" name="inactive" domain="[('active','=',False)]" />
                    </group> -->
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="action_vivienda_hora_entrada_salida">
            <field name="name">HORA DE INGRESO Y SALIDA</field>
            <field name="res_model">vivienda.hora_entrada_salida</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem name="Hora ingreso y salida" id="menu_action_vivienda_hora_entrada_salida" parent="vivienda_fiscal.menu_vf_root_conf" action="action_vivienda_hora_entrada_salida" sequence="20" />

    </data>
</odoo>