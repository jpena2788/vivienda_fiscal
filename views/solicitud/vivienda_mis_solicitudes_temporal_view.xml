<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="view_vivienda_mis_solicitud_temporal_tree">
            <field name="name">vivienda.inmueble_asignado</field>
            <field name="model">vivienda.inmueble_asignado</field>
            <field name="arch" type="xml">
                <list>
                    <field name="condicion" optional="hide"/>
                    <field name="reparto_solicitud_empleado" />
                    <field name="personal_id" />
                    <field name="reparto_id" />
                    <field name="sector_id" />
                    <field name="inmueble_id" />
                    <field name="state" widget="badge" decoration-bf="state == 'draft'" decoration-primary="state == 'por_aprobar'" decoration-success="state == 'aprobado'" decoration-warning="state == 'fin'" decoration-danger="state == 'anular'"/>
                    <button name="action_estado_por_anular" string="Anular" type="object" icon="fa-ban" class="btn-danger" invisible="state not in ['draft','por_aprobar']"/>
                    <button name="action_archivar" string="Archivar" type="object" icon="fa-archive" class="btn-secondary" invisible="(condicion == 'permanente' and state not in ['anular','baja']) or (condicion == 'temporal' and state not in ['anular','fin'])"/>
                </list>
            </field>
        </record>
        <record id="view_vivienda_mis_solicitud_temporal_form" model="ir.ui.view">
            <field name="name">vivienda.inmueble_asignado</field>
            <field name="model">vivienda.inmueble_asignado</field>
            <field name="arch" type="xml">
                <form string="NUEVO" duplicate="0">
                    <header>
                        <field name="state" widget="statusbar" statusbar_visible="draft,por_aprobar,anular,rechazado,aprobado,fin" invisible="condicion != 'temporal'"/>
                        <button name="action_estado_por_anular" string="Anular" type="object" icon="fa-ban" class="btn-secondary" invisible="state in ['draft']"/>
                        <button name="solicitar_inmueble" invisible="state != 'draft'" string="Solicitar" type="object" icon="fa-check" class="oe_highlight"/>
                    </header>
                    <sheet>
                        <!-- Bloque superior en 2 columnas -->
                        <group col="2">
                            <!-- IZQUIERDA: persona + inmueble -->
                            <group string="Datos de la Solicitud">
                                <field name="personal_id"
                                           style="color:black; font-weight: bold;font-size: x-large"
                                           domain="[('user_id', '=', uid)]"
                                           options="{'no_create': True, 'no_open': True, 'no_create_edit': True}"
                                           readonly="state != 'draft'"/>
                                <field name="personal_permitido_ids" invisible="1"/>
                                <field name="user_id"
                                           options="{'no_create': True, 'no_open': True, 'no_create_edit': True}"
                                           force_save="1" invisible="1"/>
                                <field name="inmueble_id_domain" invisible="1"/>
                                <field name="sector_temporal_dominio" invisible="1"/>
                                <field name="sector_id"
                                           string="Sector"
                                           domain="sector_temporal_dominio"
                                           options="{'no_create': True, 'no_open': True, 'no_create_edit': True}"
                                           readonly="state != 'draft'"/>
                                <field name="inmueble_id"
                                           domain="[('condicion', '=', 'temporal')] + ([('sector_id', '=', sector_id)] if sector_id else [])"
                                           options="{'no_create': True, 'no_open': True, 'no_create_edit': True}"
                                           readonly="state != 'draft'"/>
                                <field name="reparto_id" readonly="1" force_save="1"/>
                                <field name="condicion" invisible="1"/>
                                <field name="aceptacion_termino" readonly="state != 'draft'"/>
                            </group>
                            <!-- DERECHA: ambientes del inmueble -->
                            <group string="Ambientes disponibles del inmueble" invisible="not inmueble_id">
                                <field name="inmueble_ambiente_ids" nolabel="1" readonly="1">
                                    <list create="0" delete="0" edit="0">
                                        <field name="sequence" widget="handle"/>
                                        <field name="ambiente_id"/>
                                        <field name="descripcion"/>
                                        <field name="active"/>
                                    </list>
                                </field>
                            </group>
                        </group>
                        <group>
                            <group colspan="2">
                                <field name="observacion" readonly="state != 'draft'"/>
                            </group>
                            <strong colspan="2">
                                <group string="Motivo del rechazo" invisible="state != 'anular'">
                                    <strong>
                                        <h1>
                                            <field name="motivo_rechazo" colspan="4" nolabel="1"/>
                                        </h1>
                                    </strong>
                                </group>
                            </strong>
                        </group>
                        <notebook>
                            <page string="Configuración de Alojamiento" invisible="condicion == 'permanente'">
                                <group col="3">
                                    <group >
                                        <field name="fecha_inicio" readonly="state != 'draft'"/>
                                    </group>
                                    <group >
                                        <field name="fecha_fin" readonly="state != 'draft'"/>
                                    </group>
                                </group>
                                <group col="4">
                                    <group string="Hora de entrada">
                                        <h1>
                                            <field name="hora_entrada" force_save="1" nolabel="1" widget='float_time'/>
                                        </h1>
                                    </group>
                                    <group string="Hora de salida">
                                        <h1>
                                            <field name="hora_salida" force_save="1" nolabel="1" widget='float_time'/>
                                        </h1>
                                    </group>
                                    <group string="Días disponibles para pagar"  invisible="state != 'asignado'">
                                        <h1>
                                            <field name="dias_pago" force_save="1" readonly="1" />
                                        </h1>
                                    </group>
                                    <group string="Días transcurridos" invisible="state != 'asignado'">
                                        <h1>
                                            <field name="dias_transcurridos" force_save="1" readonly="1" />
                                        </h1>
                                    </group>
                                </group>
                            </page>
                            <page string="Selección de Ambientes" invisible="condicion == 'permanente'">
                                <group colspan="2">
                                    <field name="ambiente_ids" nolabel="1" mode="list" options="{'no_open': True}" context="{'default_inmueble_id': inmueble_id}">
                                        <list limit="5" editable="top">
                                            <field name="sequence" widget="handle" />
                                            <field name="solicitud_id" invisible="1" />
                                            <field name="inmueble_id" invisible="1"/>
                                            <field name="cantidad" />
                                            <field name="detalle_solicitud_id_domain" invisible="1" />
                                            <field name="detalle_solicitud_id" domain="detalle_solicitud_id_domain" options="{'no_create': True, 'no_open': True, 'no_create_edit': True}" context="{'create': 0, 'edit': 0}"/>
                                            <field name="num_personas" />
                                            <field name="condicion" invisible="1"/>
                                            <field name="fecha_inicio"  invisible="1"/>
                                            <field name="fecha_fin"  invisible="1"/>
                                            <field name="precio_diario" />
                                            <field name="precio_total" />
                                            <button name="%(vivienda_fiscal.action_inmueble_solicitud_informacion_ambiente)d" string="Información" type="action" default_focus="0" icon="fa-info" class="oe_highlight" />
                                        </list>
                                    </field>
                                </group>
                                <group string="Precio total" class="oe_subtotal_footer oe_right">
                                    <h1>
                                        <field name="precio" force_save="1" nolabel="1" />
                                    </h1>
                                </group>
                            </page>
                            <!-- POLÍTICAS -->
                            <page string="Políticas">
                                <group string="Políticas">
                                    <field name="politicas_ids" widget="many2many_tags"/>
                                </group>
                            </page>
                            <page string="Información del solicitante">
                                <group >
                                    <group >
                                        <field name="email"/>
                                        <field name="telefono"/>
                                    </group>
                                    <group >
                                        <field name="cedula_identidad"/>
                                        <field name="reparto_empleado_id"/>
                                    </group>
                                    <group colspan="2">
                                        <field name="direccion" />
                                    </group>
                                </group>
                            </page>
                        </notebook>
                        <!-- <div class="oe_chatter">
                            <field name="message_ids" widget="mail_thread" />
                        </div> -->
                    </sheet>
                </form>
            </field>
        </record>
        <record id="view_vivienda_mis_solicitud_temporal_search" model="ir.ui.view">
            <field name="name">vivienda.inmueble_asignado</field>
            <field name="model">vivienda.inmueble_asignado</field>
            <field name="arch" type="xml">
                <search string="">
                    <field name="personal_id" />
                    <field name="cedula_identidad" />
                    <field name="inmueble_id" />
                    <field name="fecha_inicio" />
                    <field name="fecha_fin" />
                    <field name="hora_entrada" />
                    <field name="hora_salida" />
                    <field name="precio" />
                    <field name="state" />
                    <field name="fecha_llegada"/>
                    <field name="fecha_salida"/>
                    <group>
                        <filter name="inmueble" string="Inmueble" context="{'group_by': 'inmueble_id'}" />
                        <filter name="estado" string="Estado" context="{'group_by': 'state'}" />
                        <filter name="search_fecha_llegada" string="Fecha Llegada" context="{'group_by': 'fecha_llegada'}"/>
                        <filter name="search_fecha_salida" string="Fecha Salida" context="{'group_by': 'fecha_salida'}"/>
                    </group>
                </search>
            </field>
        </record>
        <record model="ir.actions.act_window" id="action_vivienda_mis_solicitud_temporal">
            <field name="name">SOLICITUD DE ALOJAMIENTO TEMPORAL</field>
            <field name="res_model">vivienda.inmueble_asignado</field>
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('vivienda_fiscal.view_vivienda_mis_solicitud_temporal_tree')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('vivienda_fiscal.view_vivienda_mis_solicitud_temporal_form')}),]" />
            <field name="search_view_id" ref="vivienda_fiscal.view_vivienda_mis_solicitud_temporal_search"/>
            <field name="domain">[('user_id','=', context.get('uid')),('es_archivar','=', False),('condicion','=','temporal')]</field>
            <field name="context" eval="{'search_default_inmueble':1, 'search_default_estado':1}"></field>
        </record>
        <menuitem name="Solicitud de Alojamiento Temporal" id="menu_action_vivienda_mis_solicitud_temporal" parent="vivienda_fiscal.menu_vf_root_sol" action="action_vivienda_mis_solicitud_temporal" sequence="2" />
    </data>
</odoo>