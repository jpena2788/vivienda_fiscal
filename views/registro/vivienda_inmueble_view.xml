<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vivienda_inmueble_list" model="ir.ui.view">
        <field name="name">vivienda.inmueble.list</field>
        <field name="model">vivienda.inmueble</field>
        <field name="arch" type="xml">
            <list string="Inmuebles">
                <field name="name"/>
                <field name="address"/>
                <field name="tipo_inmueble_id"/>
                <field name="sector_id"/>
                <field name="estado"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_vivienda_inmueble_form" model="ir.ui.view">
        <field name="name">vivienda.inmueble.form</field>
        <field name="model">vivienda.inmueble</field>
        <field name="arch" type="xml">
            <form string="Inmueble">
                <sheet>
                    <!-- TITULO -->
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <!-- DATOS GENERALES -->
                    <group string="Información General">
                        <group>
                            <field name="description"/>
                            <field name="address"/>
                            <field name="tipo_inmueble_id"/>
                            <field name="sector_id"/>
                        </group>
                        <group>
                            <field name="bloque"/>
                            <field name="numero"/>
                            <field name="estado"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <!-- CONFIGURACIÓN -->
                    <group string="Configuración de Reserva">
                        <group>
                            <field name="hora_entrada"/>
                            <field name="hora_salida"/>
                        </group>
                        <group>
                            <field name="dia_anticipacion"/>
                            <field name="dia_anticipacion_maximo"/>
                        </group>
                    </group>
                    <!-- CONTROL -->
                    <group string="Control">
                        <group>
                            <field name="numero_habitacion_reservada"/>
                            <field name="habitacion_usuario"/>
                            <field name="dias_pago"/>
                        </group>
                    </group>
                    <!-- POLÍTICAS -->
                    <group string="Políticas">
                        <field name="politicas_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
