<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="view_vivienda_catalogo_caracteristica_tree">
            <field name="name">vivienda.catalogo_caracteristica</field>
            <field name="model">vivienda.catalogo_caracteristica</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name" />
                    <field name="descripcion" />
                    <field name="caracteristica_valor_ids" widget="many2many_tags" />
                </list>
            </field>
        </record>
        <record id="view_vivienda_catalogo_caracteristica_form" model="ir.ui.view">
            <field name="name">vivienda.catalogo_caracteristica</field>
            <field name="model">vivienda.catalogo_caracteristica</field>
            <field name="arch" type="xml">
                <form string="NUEVO" duplicate="0">
                    <sheet>
                        <group>
                            <group>
                                <field name="name" />
                                <field name="active" widget="boolean_toggle" />
                            </group>
                            <group>
                                <field name="descripcion" />
                            </group>
                            <group>
                                <field name="caracteristica_valor_ids">
                                    <list string="Values" editable="bottom">
                                        <field name="sequence" widget="handle" />
                                        <field name="name" string="Valor" />
                                    </list>
                                </field>
                            </group>
                        </group>
                        <div class="oe_chatter">
                            <field name="message_ids" widget="mail_thread" />
                        </div>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="view_vivienda_catalogo_caracteristica_presentacion_form" model="ir.ui.view">
            <field name="name">vivienda.catalogo_caracteristica</field>
            <field name="model">vivienda.catalogo_caracteristica</field>
            <field name="arch" type="xml">
                <form string="NUEVO">
                    <sheet>
                        <group>
                            <group>
                                <field name="name" readonly="1" />
                            </group>
                            <group>
                                <field name="descripcion" readonly="1" />
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="view_vivienda_catalogo_caracteristica_search" model="ir.ui.view">
            <field name="name">vivienda.catalogo_caracteristica</field>
            <field name="model">vivienda.catalogo_caracteristica</field>
            <field name="arch" type="xml">
                <search string="">
                    <field name="name" />
                    <field name="descripcion" />
                    <group>
                        <filter string="Inactivo" name="inactive" domain="[('active','=',False)]" />
                    </group>
                </search>
            </field>
        </record>
        <record model="ir.actions.act_window" id="action_vivienda_catalogo_caracteristica">
            <field name="name">CARACTERÍSTICAS DE LAS HABITACIONES</field>
            <field name="res_model">vivienda.catalogo_caracteristica</field>
            <field name="view_mode">list,form</field>
        </record>
        <menuitem id="menu_action_vivienda_catalogo_caracteristica"
                  name="Características"
                  parent="vivienda_fiscal.menu_vf_root_conf"
                  sequence="2"
                  action="action_vivienda_catalogo_caracteristica" />
    </data>
</odoo>