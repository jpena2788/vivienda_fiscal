<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="view_vivienda_tipo_ambiente_inmueble_tree">
            <field name="name">vivienda.tipo_ambiente_inmueble</field>
            <field name="model">vivienda.tipo_ambiente_inmueble</field>
            <field name="arch" type="xml">
                <list>
                    <field name="tipo_ambiente_id" />
                    <field name="inmueble_id" />
                    <field name="caracteristicas_ids" widget="many2many_tags" />
                </list>
            </field>
        </record>
        <record id="view_vivienda_tipo_ambiente_inmueble_search" model="ir.ui.view">
            <field name="name">vivienda.tipo_ambiente_inmueble</field>
            <field name="model">vivienda.tipo_ambiente_inmueble</field>
            <field name="arch" type="xml">
                <search string="">
                    <field name="inmueble_id" />
                    <field name="tipo_ambiente_id" />
                    <field name="caracteristicas_ids"/>
                    <group>
                        <filter name="inmueble" string="Agrupar Inmueble" context="{'group_by': 'inmueble_id'}" />
                        <filter string="Eliminado" name="inactive" domain="[('active','=',False)]" />
                    </group>
                </search>
            </field>
        </record>
        <record id="view_vivienda_tipo_ambiente_inmueble_form" model="ir.ui.view">
            <field name="name">vivienda.tipo_ambiente_inmueble</field>
            <field name="model">vivienda.tipo_ambiente_inmueble</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="marca" create="true" delete="true" edit="true">
                    <header></header>
                    <sheet>
                        <group>
                            <group colspan="2">
                                <field name="inmueble_id" required="1" placeholder="Seleccione el inmueble" options="{'no_create': True, 'no_open': True, 'no_create_edit': True}" />
                            </group>
                            <group>
                                <field name="tipo_ambiente_id_domain" invisible="1" />
                                <field name="tipo_ambiente_id" domain="tipo_ambiente_id_domain" placeholder="Escriba el tipo de ambiente.." options="{'no_create': True, 'no_open': True, 'no_create_edit': True}"/>
                                <field name="num_personas"/>
                                <field name="active" widget="boolean_toggle" />
                            </group>
                            <group>
                                <field name="descripcion" placeholder="Escriba alguna descripción.." />
                                <field name="precio" placeholder="Escriba el precio de este tipo de ambbiente.." />
                            </group>
                        </group>
                        <group string="Características">
                            <group >
                                <field name="caracteristicas_ids" nolabel="1">
                                    <list editable="top">
                                        <field name="caracteristica_id_domain" invisible="1" />
                                        <field name="caracteristica_id" domain="caracteristica_id_domain" options="{'no_create': True, 'no_open': True, 'no_create_edit': True}" />
                                        <field name="valor_ids" widget="many2many_tags"/>
                                    </list>
                                </field>
                            </group>
                        </group>
                    </sheet>
                    <!-- <div class="oe_chatter">
                        <field name="message_ids" widget="mail_thread" />
                    </div> -->
                </form>
            </field>
        </record>
        <record id="view_vivienda_tipo_ambiente_inmueble_one2many_form" model="ir.ui.view">
            <field name="name">vivienda.tipo_ambiente_inmueble</field>
            <field name="model">vivienda.tipo_ambiente_inmueble</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="marca" create="true" delete="true" edit="true">
                    <header></header>
                    <sheet>
                        <group>
                            <group>
                                <field name="tipo_ambiente_id_domain" invisible="1" />
                                <field name="tipo_ambiente_id" domain="tipo_ambiente_id_domain" options="{'no_create': True, 'no_open': True, 'no_create_edit': True}" placeholder="Seleccione el tipo de habitación.." />
                                <field name="num_personas"/>
                                <field name="active" widget="boolean_toggle" />
                            </group>
                            <group>
                                <field name="precio" placeholder="Escriba el precio de este tipo de habitación.." />
                            </group>
                            <group colspan="2" string="Características">
                                <field name="caracteristicas_ids" nolabel="1">
                                    <list editable="top">
                                        <field name="caracteristica_id_domain" invisible="1" />
                                        <field name="caracteristica_id" domain="caracteristica_id_domain" options="{'no_create': True, 'no_open': True, 'no_create_edit': True}" />
                                        <field name="valor_ids" widget="many2many_tags"/>
                                    </list>
                                </field>
                            </group>
                        </group>
                    </sheet>
                    <!-- <div class="oe_chatter">
                        <field name="message_ids" widget="mail_thread" />
                    </div> -->
                </form>
            </field>
        </record>
        <record model="ir.actions.act_window" id="action_vivienda_tipo_ambiente_inmueble">
            <field name="name">Tipos de ambientes por inmueble</field>
            <field name="res_model">vivienda.tipo_ambiente_inmueble</field>
            <field name="view_mode">list,form</field>
            <!-- <field name="context" eval="{'search_default_reparto':1,'search_default_hospedaje':1}"></field> -->
        </record>
        <record id="action_vivienda_tipo_ambiente_inmueble_server" model="ir.actions.server">
            <field name="name">Tipos de ambientes por inmueble</field>
            <field name="model_id" ref="model_vivienda_tipo_ambiente_inmueble" />
            <field name="binding_model_id" ref="model_vivienda_tipo_ambiente_inmueble" />
            <field name="state">code</field>
            <field name="code">action = env['vivienda.tipo_ambiente_inmueble'].ver_tipo_habitacion()</field>
        </record>
        <menuitem name="Tipo de Ambiente Inmueble" id="menu_action_inmueble_tipo_ambiente" parent="vivienda_fiscal.menu_vf_root_reg" action="action_vivienda_tipo_ambiente_inmueble" sequence="3" />
    </data>
</odoo>