<odoo>
  <data>
      <record model="ir.ui.view" id="view_hospedaje_cuentas_bancarias_tree">
          <field name="name">hospedaje.cuentas_bancarias</field>
          <field name="model">hospedaje.cuentas_bancarias</field>
          <field name="arch" type="xml">
            <list>
                <field name="cuentas" />
                <!-- <field name="tipo_cuenta" /> -->
                <field name="reparto_id" />
                <field name="banco" />
                <field name="numero_de_cuenta" />
                <field name="cedula" />
                <field name="nombre" />
                <field name="observacion" />
            </list>
        </field>
      </record>
      <record id="view_hospedaje_cuentas_bancarias_form" model="ir.ui.view">
        <field name="name">hospedaje.cuentas_bancarias</field>
        <field name="model">hospedaje.cuentas_bancarias</field>
        <field name="arch" type="xml">
            <form string="NUEVO" duplicate="0">
                <sheet>
                    <group>
                        <group colspan="2">
                            <field name="reparto_id" options="{'no_create': True, 'no_open': True, 'no_create_edit': True}"/>
                            <field name="banco"/>
                            <field name="cuentas"/>
                            <!-- <field name="tipo_cuenta" required="1" widget="many2many_tags" options="{'no_create': True, 'no_open': True, 'no_create_edit': True}" /> -->
                            <field name="numero_de_cuenta"/>
                            <field name="cedula"/>
                            <field name="nombre"/>
                            <field name="observacion"/>

                        </group>
                    </group>
                   
                </sheet>
            </form>
        </field>
    </record>


      <record model="ir.actions.act_window" id="action_hospedaje_cuentas_bancarias">
        <field name="name">TIPO DE CUENTA</field>
        <field name="res_model">hospedaje.cuentas_bancarias</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem name="Tipo de cuenta" id="menu_action_hospedaje_cuentas_bancarias" parent="hospedaje_menu_ayuda" action="action_hospedaje_cuentas_bancarias" sequence="30" />


</data>
</odoo>