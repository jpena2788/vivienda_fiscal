<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vf_tipo_inmueble_list" model="ir.ui.view">
        <field name="name">vivienda.tipo.inmueble.list</field>
        <field name="model">vivienda.tipo_inmueble</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_vf_tipo_inmueble_search" model="ir.ui.view">
        <field name="name">vivienda.tipo.inmueble.search</field>
        <field name="model">vivienda.tipo_inmueble</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="active"/>
                <filter name="active" string="Activos" domain="[('active', '=', True)]"/>
            </search>
        </field>
    </record>
    <record id="view_vf_tipo_inmueble_form" model="ir.ui.view">
        <field name="name">vivienda.tipo.inmueble.form</field>
        <field name="model">vivienda.tipo_inmueble</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_vf_tipo_inmueble" model="ir.actions.act_window">
        <field name="name">Tipos de Inmuebles</field>
        <field name="res_model">vivienda.tipo_inmueble</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_vf_tipo_inmueble"
                  name="Tipo de Inmueble"
                  parent="vivienda_fiscal.menu_vf_root_conf"
                  sequence="4"
                  action="action_vf_tipo_inmueble" />
</odoo>