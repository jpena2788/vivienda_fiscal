<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="view_vivienda_solicitud_tree">
            <field name="name">vivienda.solicitud_asignacion</field>
            <field name="model">vivienda.solicitud_asignacion</field>
            <field name="arch" type="xml">
                <list>
                    <field name="personal_id" />
                    <field name="reparto_id" />
                    <field name="inmueble_id" />
                    <field name="state" widget="badge" decoration-bf="state == 'draft'" decoration-primary="state == 'por_aprobar'" decoration-success="state == 'aprobar'" decoration-warning="state == 'llegada' or state == 'fin'" decoration-danger="state == 'anular'"/>
                    <button name="action_llegada" string="Recepción" type="object" icon="fa-thumbs-up" class="btn-primary" invisible="state != 'aprobar'"/>
                    <button name="action_salida" string="Salida" type="object" icon="fa-times-circle" class="btn-warning"  invisible="state != 'llegada'"/>
                    <button name="action_archivar" string="Archivar" type="object" icon="fa-archive" class="btn-secondary" invisible="state not in ['draft','anular','fin']"/>
                </list>
            </field>
        </record>
        <record id="view_vivienda_solicitud_form" model="ir.ui.view">
            <field name="name">vivienda.solicitud_asignacion</field>
            <field name="model">vivienda.solicitud_asignacion</field>
            <field name="arch" type="xml">
                <form string="NUEVO" duplicate="0">
                    <header>
                        <field name="state" widget="statusbar"/>
                        <button name="asignacion_solicitud" string="Asignar" type="object" icon="fa-check" class="btn-warning" invisible="state != 'por_aprobar'"/>
                        <button name="aprobar_solicitud" string="Aprobar" type="object" icon="fa-check" class="btn-success" invisible="state != 'pagado'"/>
                    </header>
                    <sheet>
                        <group>
                            <group colspan="2">
                                <field name="personal_id" style="color:black; font-weight: bold;font-size: x-large" options="{'no_create': True, 'no_open': True, 'no_create_edit': True}" readonly="state != 'draft'"/>
                                <field name="user_id" options="{'no_create': True, 'no_open': True, 'no_create_edit': True}" force_save="1" invisible="1" />
                            </group>
                            <group >
                                <!-- <field name="inmueble_id_domain" invisible="1" /> -->
                                <field name="inmueble_id" options="{'no_create': True, 'no_open': True, 'no_create_edit': True}" readonly="state != 'draft'"/>
                            </group>
                        </group>
                        <group>
                            <group colspan="2">
                                <field name="observacion" readonly="state != 'draft'"/>
                            </group>
                            <strong colspan="2">
                                <group string="Motivo del rechazo" invisible="state != 'anular'">
                                    <strong>
                                        <h1>
                                            <field name="motivo_rechazo" colspan="4" nolabel="1"/>
                                        </h1>
                                    </strong>
                                </group>
                            </strong>
                        </group>
                        <notebook>
                            <page string="Selección de Inmueble" invisible="state != 'draft'">
                                <group colspan="2">
                                    <field name="tipo_ambiente_ids" nolabel="1" context="{'default_inmueble_id': inmueble_id}">
                                        <list limit="5" editable="top">
                                            <field name="sequence" widget="handle" />
                                            <field name="solicitud_id" required="0" invisible="1" />
                                            <field name="inmueble_id" invisible="1"/>
                                            <field name="cantidad" />
                                        </list>
                                    </field>
                                </group>
                            </page>
                            <page string="Información del solicitante">
                                <group >
                                    <group >
                                        <field name="email"/>
                                        <field name="telefono"/>
                                    </group>
                                    <group >
                                        <field name="cedula_identidad"/>
                                        <field name="reparto_id"/>
                                    </group>
                                    <group colspan="2">
                                        <field name="direccion" />
                                    </group>
                                </group>
                            </page>
                        </notebook>
                        <!-- <div class="oe_chatter">
                            <field name="message_ids" widget="mail_thread" />
                        </div> -->
                    </sheet>
                </form>
            </field>
        </record>
