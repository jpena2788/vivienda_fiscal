<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vf_mantenimiento_list" model="ir.ui.view">
        <field name="name">vf.vivienda.mantenimiento.list</field>
        <field name="model">vf.vivienda.mantenimiento</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="vivienda_id"/>
                <field name="alojamiento_id"/>
                <field name="fecha_inicio"/>
                <field name="estado"/>
            </list>
        </field>
    </record>

    <record id="view_vf_mantenimiento_form" model="ir.ui.view">
        <field name="name">vf.vivienda.mantenimiento.form</field>
        <field name="model">vf.vivienda.mantenimiento</field>
        <field name="arch" type="xml">
            <form string="Mantenimiento">
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="descripcion"/>
                        <field name="vivienda_id"/>
                        <field name="alojamiento_id"/>
                        <field name="fecha_inicio"/>
                        <field name="fecha_finalizacion"/>
                        <field name="estado"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vf_mantenimiento" model="ir.actions.act_window">
        <field name="name">Mantenimiento</field>
        <field name="res_model">vf.vivienda.mantenimiento</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
