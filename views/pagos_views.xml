<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vf_pagos_list" model="ir.ui.view">
        <field name="name">vf.vivienda.pagos.list</field>
        <field name="model">vf.vivienda.pagos</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="vivienda_id"/>
                <field name="alojamiento_id"/>
                <field name="fecha"/>
                <field name="monto"/>
            </list>
        </field>
    </record>

    <record id="view_vf_pagos_form" model="ir.ui.view">
        <field name="name">vf.vivienda.pagos.form</field>
        <field name="model">vf.vivienda.pagos</field>
        <field name="arch" type="xml">
            <form string="Pagos de Vivienda">
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="vivienda_id"/>
                        <field name="alojamiento_id"/>
                        <field name="fecha"/>
                        <field name="monto"/>
                        <field name="currency_id"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vf_pagos" model="ir.actions.act_window">
        <field name="name">Pagos</field>
        <field name="res_model">vf.vivienda.pagos</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
