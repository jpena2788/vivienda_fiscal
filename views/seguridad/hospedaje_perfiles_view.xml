<odoo>
    <data>
        <!-- TREE -->
        <record id="view_hospedaje_perfiles_tree" model="ir.ui.view">
            <field name="name">res.users.tree.hospedaje</field>
            <field name="model">res.users</field>
            <field name="arch" type="xml">
                <list string="Usuarios" create="false" delete="false">
                    <field name="name"/>
                    <field name="login"/>
                    <field name="company_id"/>
                </list>
            </field>
        </record>
        <!-- FORM HEREDADO -->
        <record id="view_hospedaje_perfiles_form" model="ir.ui.view">
            <field name="name">res.users.form.hospedaje</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/>
            <field name="arch" type="xml">
                <!-- SOLO agregamos una pestaña -->
                <xpath expr="//notebook" position="inside">
                    <page string="PERFILES">
                        <group>
                            <div class="o_form_label">
                                Los permisos se gestionan desde la pestaña Accesos del usuario.
                            </div>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
        <!-- SEARCH -->
        <!-- <record id="view_hospedaje_perfiles_search" model="ir.ui.view">
            <field name="name">res.users.search.hospedaje</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_search"/>
            <field name="arch" type="xml">
                <xpath expr="//search" position="inside">
                    <field name="login"/>
                    <field name="name"/>
                    <field name="company_id"/>
                    <filter name="inactive"
                string="Inactivo"
                domain="[('active','=',False)]"/>
                    <group expand="0" string="Agrupar">
