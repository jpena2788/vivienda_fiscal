<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>

        <record id="view_inmueble_informacion_ambiente_form" model="ir.ui.view">
            <field name="name">Anulación de solicitud</field>
            <field name="model">vivienda.informacion_ambiente</field>
            <field name="arch" type="xml">
                <form string="Reject Request" version="7.0">
                    <h1>
                        <field name="solicitud_ambiente_id" options="{'no_create': True, 'no_open': True, 'no_create_edit': True}" invisible="1" />
                        <field name="tipo_ambiente_id" options="{'no_create': True, 'no_open': True, 'no_create_edit': True}" readonly="1" class="oe_center"/>
                    </h1>
                    <group>
                        <group string="Número de personas">
                            <strong>
                                <h1>
                                    <field name="num_personas" nolabel="1" readonly="1"/>
                                </h1>
                            </strong>
                        </group>
                        <group colspan="2" string="Características del ambiente">
                            <field name="caracteristicas_ids" nolabel="1" options="{'no_create': True, 'no_open': True, 'no_create_edit': True}" readonly="1">
                                <list >
                                    <field name="caracteristica_id_domain" invisible="1" />
                                    <field name="caracteristica_id" domain="caracteristica_id_domain" options="{'no_create': True, 'no_open': True, 'no_create_edit': True}" />
                                    <field name="valor_ids" widget="many2many_tags" />
                                </list>
                            </field>
                        </group>

                    </group>
                    <footer>
                        <button string="Aceptar" class="oe_link" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_inmueble_solicitud_informacion_ambiente" model="ir.actions.act_window">
            <field name="name">Información de ambiente</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">vivienda.informacion_ambiente</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

    </data>
</openerp>
