                    string="Agrupar por reparto"
                    context="{'group_by':'company_id'}"/>
                    </group>
                </xpath>
            </field>
        </record> -->
        <!-- ACTION -->
        <record id="action_hospedaje_perfiles" model="ir.actions.act_window">
            <field name="name">Perfiles</field>
            <field name="res_model">res.users</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_hospedaje_perfiles_tree"/>
            <!-- <field name="search_view_id" ref="view_hospedaje_perfiles_search"/> -->
        </record>
        <!-- MENU -->
        <menuitem name="Perfiles"
              id="menu_action_hospedaje_perfiles"
              parent="menu_hospedaje_seguridad"
              action="action_hospedaje_perfiles"
              sequence="20"/>
    </data>
</odoo>